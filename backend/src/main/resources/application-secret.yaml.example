# ------------------------------------------------------------------
# 로컬 개발용 비밀값 템플릿.
#
# 사용법:
#   1) 이 파일을 같은 폴더에 application-secret.yaml 이름으로 복사
#   2) 아래 값을 실제 로컬 MySQL 계정/비밀번호로 채우기
#   3) application-secret.yaml 은 .gitignore 에 등록되어 있어 커밋되지 않음
#
# application.yaml 이 spring.config.import 로 이 파일을 optional 하게 읽어들이므로,
# 파일이 없으면 그냥 무시되고 application.yaml 의 ${DB_USERNAME:root} 같은
# 기본값/환경변수가 대신 사용됩니다. 즉 이 파일은 "있으면 우선 적용, 없어도 안 죽음".
#
# 팀원마다 로컬 MySQL 계정이 다를 수 있으니, 이 파일은 각자 로컬에만 두고 공유하지 마세요.
# ------------------------------------------------------------------

spring:
  datasource:
    url: jdbc:mysql://localhost:3306/kiwobollae?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
    username: root
    password: your_local_mysql_password

jwt:
  secret: local-dev-secret-change-me-please-make-this-long-and-random
  access-expiration: 3600000
  refresh-expiration: 1209600000
