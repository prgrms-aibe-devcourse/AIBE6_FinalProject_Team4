# ------------------------------------------------------------------
# 환경변수 템플릿.
#
# 사용법:
#   cp .env.example .env
#   .env 를 실제 값으로 채운 뒤 아래 방법 중 하나로 로드해서 실행:
#     - IntelliJ "EnvFile" 플러그인으로 Run Configuration에 .env 연결
#     - docker-compose 사용 시 env_file: .env 로 컨테이너에 주입
#     - 쉘에서 직접 export 후 실행 (PowerShell 예: Get-Content .env | ...로 로드하거나 수동 export)
#
#   Spring Boot는 .env 파일을 기본적으로 읽지 않습니다 — 아래 값들은 실제로는
#   application.yaml 의 ${DB_USERNAME:root} 같은 플레이스홀더와 매칭되는
#   "진짜 OS 환경변수"로 주입되어야 적용됩니다. 로컬 IDE에서 편하게 쓰려면
#   application-secret.yaml (application-secret.yaml.example 참고) 방식을 대신 써도 됩니다.
#
#   이 파일은 .gitignore 에 등록되어 있어 실제 값이 채워진 .env는 커밋되지 않습니다.
# ------------------------------------------------------------------

# --- Database ---
DB_URL=jdbc:mysql://localhost:3306/kiwobollae?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
DB_USERNAME=root
DB_PASSWORD=your_local_mysql_password

# --- JWT ---
JWT_SECRET=change_me_to_a_long_random_string
JWT_ACCESS_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=1209600000

# --- Spring profile (local / prod) ---
SPRING_PROFILES_ACTIVE=local
